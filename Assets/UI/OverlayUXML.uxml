<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <ui:VisualElement style="flex-grow: 1; justify-content: flex-start;">
        <ui:Button text="Settings" name="settingsBtn" style="position: absolute; top: 5px; left: 0; margin-top: 6px; margin-right: 6px; margin-bottom: 6px; margin-left: 6px;" />
        <ui:ProgressBar value="22" title="suspicion" name="suspicionBar" style="width: 158px; align-content: auto; justify-content: space-around; align-items: stretch; margin-top: 6px; margin-right: 6px; margin-bottom: 6px; margin-left: 6px; background-color: rgb(161, 186, 18); -unity-background-image-tint-color: rgb(156, 72, 72); background-image: none; flex-direction: column; left: 150px; top: 10px;" />
    </ui:VisualElement>
</ui:UXML>
